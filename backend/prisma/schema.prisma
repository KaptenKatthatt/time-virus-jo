// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Player {
  id           String      @id @map("_id")
  name         String
  game         Game?       @relation(fields: [gameId], references: [id])
  gameId       String?     @db.ObjectId
  scoreboard   Scoreboard? @relation(fields: [scoreboardId], references: [id])
  scoreboardId String?     @db.ObjectId
}

// Data for currently running game(room)
model Game {
  id               String  @id @default(auto()) @map("_id") @db.ObjectId
  name             String?
  player_one_name  String?
  player_two_name  String?
  player_one_score Int?
  player_two_score Int?

  // startTime     Int? //Kept in memory during game instead
  // clickTime1    Int?
  // clickTime2    Int?
  player_one_id String
  player_two_id String?
  fastest_Time  String?
  players       Player[]
}

// Data for archived games
model Scoreboard {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  name             String?
  player_one_name  String
  player_two_name  String
  player_one_score Int
  player_two_score Int
  players          Player[]
}
