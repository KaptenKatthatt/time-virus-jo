{
  "name": "backend",
  "version": "1.0.0",
  "main": "dist/server.js",
  "scripts": {
    "build": "npx prisma generate && node scripts/build.js",
    "check": "run-s lint typecheck type-coverage",
    "debug": "cross-env DEBUG=backend:*,socket.io:socket tsx --watch src/server.ts",
    "dev": "cross-env DEBUG=backend:* tsx --watch src/server.ts",
    "lint": "eslint .",
    "pre-deploy": "npx prisma migrate deploy && npx prisma db seed",
    "typecheck": "tsc --noEmit",
    "type-coverage": "type-coverage -p tsconfig.json --at-least 100 --detail --ignore-files \"generated/**/*.ts\" --ignore-files \"prisma/seed.ts\"",
    "start": "NODE_ENV=production node dist/server.js"
  },
  "keywords": [],
  "author": "Johan Nordström <johan@digitalvillage.se>",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@prisma/client": "6.19",
    "cors": "^2.8.5",
    "cross-env": "^10.1.0",
    "debug": "^4.4.3",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "lodash": "^4.17.21",
    "morgan": "^1.10.1",
    "socket.io": "^4.8.3",
    "supports-color": "^10.2.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/cors": "^2.8.19",
    "@types/debug": "^4.1.12",
    "@types/express": "^5.0.6",
    "@types/lodash": "^4.17.21",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.2.0",
    "env-cmd": "^11.0.0",
    "eslint": "^9.39.2",
    "globals": "^17.1.0",
    "npm-run-all2": "^8.0.4",
    "prisma": "6.19",
    "tsx": "^4.21.0",
    "type-coverage": "^2.29.7",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.53.1"
  }
}
